# Wildcard edge test: [pattern_*] -> [target]

[t_a]: output = "a"
[t_b]: output = "b"
[t_c]: output = "c"
[other]: output = "other"

[collect]: output = [$t_a.output, $t_b.output, $t_c.output]

[verify()]: {
  assert len($collect.output) == 3
  assert "a" in $collect.output
  assert "b" in $collect.output
  assert "c" in $collect.output
}
[run_verify]: verify()

# Wildcard fan-in: all t_* nodes -> collect -> verify
[t_*] -> [collect] -> [run_verify]
