# Classifier node that sets the intent
[classify]: intent = "question"

# Handler nodes
[handle_question]: notify(message="Handling a question!")
[handle_task]: notify(message="Handling a task!")
[handle_other]: notify(message="Handling something else!")

# Switch routing based on intent
[classify] -> switch intent {
    "question": [handle_question]
    "task": [handle_task]
    default: [handle_other]
}
