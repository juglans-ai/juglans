# decorator_simple_test.jg — 验证 @ 装饰器解析和编译期展开

[Router]: {
  routes: str = "[]"
}

[Router.register(self, path, handler)]: {
  print(message="Registered: " + path + " -> " + handler)
}

[router]: new Router()

@router.register("/api/hello")
[hello()]: {
  yield { type: "content", text: "hello from decorated function" }
}

[start]: print(message="done")

[_deco_0] -> [start]
