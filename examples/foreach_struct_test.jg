libs: ["../std/ai.jg"]

[t1]: ai.tool {
  name="web_search",
  description="Search the web",
  params={"query": {"type": "string", "description": "Search query"}},
  required=["query"],
  text="Search web for info"
}

[t2]: ai.tool {
  name="get_time",
  description="Get current time",
  params={},
  text="Get current UTC time"
}

[all]: output = [t1, t2]

[build]: foreach parallel(t in all.output) {
  [convert]: t.to_schema()
  [point]: output = {"id": t.name, "text": t.text, "payload": {"definition": t.schema}}
  [convert] -> [point]
}

[verify()]: {
  assert len(build.output) == 2
}
[run_verify]: verify()

[t1] -> [t2] -> [all] -> [build] -> [run_verify]
