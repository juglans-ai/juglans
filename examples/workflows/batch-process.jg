prompts: ["../prompts/*.jgx"]

[analyst]: {
  "model": "gpt-4o",
  "system_prompt": "You are a data analyst. Provide clear, data-driven insights.",
  "temperature": 0.3
}

# 初始化上下文
[init]: results = [], processed = 0

[start_notify]: notify(status="Starting batch processing...")

# 批量处理循环
[process_loop]: foreach(item in input.items) {
  # 使用 prompt 模板
  [render]: p(
    slug="data-analysis",
    data=[item],
    focus="key metrics"
  )

  # 调用分析 Agent
  [analyze]: chat(
    agent=analyst,
    message=output
  )

  # 收集结果
  [collect]: results = append(results, {
      "id": item.id,
      "analysis": output
    }), processed = processed + 1

  # 进度通知
  [progress]: notify(
    status="Processed " + processed + " / " + len(input.items)
  )

  [render] -> [analyze] -> [collect] -> [progress]
}

# 生成摘要
[summary]: chat(
  agent=analyst,
  message="Summarize these analysis results: " + json(results)
)

[done]: notify(status="Completed! Total processed: " + processed)

# 执行流程
[analyst] -> [init] -> [start_notify] -> [process_loop] -> [summary] -> [done]
