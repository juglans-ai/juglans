# Inline agent definition
[assistant]: {
  "model": "gpt-4o",
  "system_prompt": "You are a helpful, friendly assistant.",
  "temperature": 0.7
}

# 开始节点
[start]: notify(status="Chat started...")

# 调用 Agent 进行对话
[chat]: chat(
  agent=assistant,
  message=input.message
)

# 结束节点
[end]: notify(status="Chat completed")

# 执行流程
[assistant] -> [start] -> [chat] -> [end]
