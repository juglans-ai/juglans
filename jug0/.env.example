# ============================================
# jug0 — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Database ---
PG_PASSWORD=jug0
DATABASE_URL=postgresql://jug0:jug0@localhost:5432/jug0_db

# --- Redis ---
REDIS_URL=redis://127.0.0.1:6379

# --- Vector DB (Qdrant) ---
QDRANT_URL=http://localhost:6334

# --- Server ---
HOST=0.0.0.0
PORT=3000

# --- Auth ---
JWT_SECRET=change-me-to-a-random-string
EXECUTION_SIGNING_KEY=change-me-in-production

# --- Official Org ---
# The org slug used for built-in/public agents, prompts, workflows.
# OFFICIAL_ORG_SLUG=juglans_official

# --- LLM Providers ---
OPENAI_API_KEY=sk-your-openai-key
# OPENAI_API_BASE=https://api.openai.com/v1
DEEPSEEK_API_KEY=sk-your-deepseek-key
GEMINI_API_KEY=your-google-api-key
QWEN_API_KEY=your-qwen-api-key
DASHSCOPE_API_KEY=your-dashscope-key

# --- Search ---
TAVILY_API_KEY=your-tavily-key

# --- LLM Defaults ---
DEFAULT_LLM_PROVIDER=qwen
DEFAULT_LLM_MODEL=qwen-plus

# --- Memory / Embeddings ---
ENABLE_MEMORY=false
ENABLE_AGENT_MEMORY=false
MEMORY_EMBEDDING_DIM=1024
MEMORY_EMBEDDING_MODEL=text-embedding-v4

# --- Storage ---
UPLOAD_DIR=./uploads

# --- Logging ---
RUST_LOG=jug0=debug,tower_http=debug
