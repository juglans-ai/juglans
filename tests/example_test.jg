[test_config]: config(budget=1.0)

[test_setup]: greeting = "Hello, test_user!"

[test_ctx_contains]: {
  msg = "Hello, world!"
  assert(ctx_contains="Hello", ctx_path="msg")
}

[test_ctx_not_found]: {
  msg = "Hello, world!"
  assert(ctx_contains="NOTFOUND", ctx_path="msg")
}

[test_tool_trace]: {
  status = "ok"
  assert(tool_called="set_context")
}
